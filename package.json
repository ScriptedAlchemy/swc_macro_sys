{
  "name": "swc-macro-wasm-example",
  "version": "1.0.0",
  "type": "module",
  "description": "Example usage of SWC Macro WASM bindings",
  "main": "example_wasm_usage.js",
  "scripts": {
    "start": "node --experimental-wasm-modules example_wasm_usage.js",
    "build-wasm": "cd crates/swc_macro_wasm && wasm-pack build --release",
    "test": "run-s test:rust test:js",
    "test:rust": "cargo test --workspace",
    "test:js": "pnpm -r test",
    "test:all": "run-s test:rust test:js:all",
    "test:js:all": "run-p test:root test:workspaces",
    "test:root": "vitest run",
    "test:workspaces": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "test:e2e": "pnpm -r test:e2e",
    "test:watch": "run-p test:watch:root test:watch:workspaces",
    "test:watch:root": "vitest --watch",
    "test:watch:workspaces": "pnpm -r --parallel test:watch",
    "test:ui": "vitest --ui",
    "test:coverage": "run-s test:coverage:rust test:coverage:js",
    "test:coverage:rust": "cargo tarpaulin --workspace --out Html --output-dir coverage/rust",
    "test:coverage:js": "run-s test:coverage:root test:coverage:workspaces",
    "test:coverage:root": "vitest run --coverage",
    "test:coverage:workspaces": "pnpm -r test:coverage",
    "test:ci": "run-s build test:all",
    "build": "run-s build:rust build:js",
    "build:rust": "cargo build --release --workspace",
    "build:js": "pnpm -r --filter=!examples/module-federation-example --filter=!examples/module-federation-web-example build",
    "optimize:examples": "pnpm -C examples/module-federation-example optimize && pnpm -C examples/module-federation-web-example optimize",
    "examples:build-rsbuild": "pnpm -C examples/rsbuild-project install --prefer-frozen-lockfile=false && pnpm -C examples/rsbuild-project build",
    "build-and-test": "run-s build-wasm build examples:build-rsbuild optimize:examples test:all",
    "lint": "run-s lint:rust lint:js",
    "lint:rust": "cargo clippy --workspace -- -D warnings",
    "lint:js": "pnpm -r lint",
    "clean": "run-p clean:rust clean:js clean:coverage",
    "clean:rust": "cargo clean",
    "clean:js": "pnpm -r clean",
    "clean:coverage": "rimraf coverage"
  },
  "dependencies": {
    "@types/node": "^20.0.0"
  },
  "devDependencies": {
    "@swc/core": "^1.3.0",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.0",
    "vite-plugin-top-level-await": "^1.5.0",
    "vite-plugin-wasm": "^3.4.1",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "packageManager": "pnpm@8.11.0+sha512.9df87c16c98db27b4e051d787e67f2207ec47e809ccb07bf7b5ec4acdcd1613355839a38d0b900144923d6a7057700b74d2a0ccb1558beb241647a1206a9a7ab",
  "pnpm": {
    "overrides": {
      "@rspack/cli": "npm:@rspack-canary/cli@1.4.11-canary-1c16f486-20250724191319",
      "@rspack/core": "npm:@rspack-canary/core@1.4.11-canary-1c16f486-20250724191319"
    }
  }
}
