{
  "name": "swc-macro-wasm-example",
  "version": "1.0.0",
  "type": "module",
  "description": "Example usage of SWC Macro WASM bindings",
  "main": "example_wasm_usage.js",
  "scripts": {
    "start": "node --experimental-wasm-modules example_wasm_usage.js",
    "build": "pnpm run build:rust && pnpm run build:wasm && pnpm run build:js",
    "build:rust": "cargo build --release --workspace",
    "build:wasm": "cd crates/swc_macro_wasm && wasm-pack build --release",
    "build:js": "pnpm -r --filter=!examples/module-federation-example --filter=!examples/module-federation-web-example build",
    "test": "pnpm run build && pnpm install && cargo test --workspace && pnpm -r test",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "cargo tarpaulin --workspace --out Html --output-dir coverage/rust && vitest run --coverage",
    "lint": "cargo clippy --workspace -- -D warnings && pnpm -r lint",
    "clean": "cargo clean && pnpm -r clean && rimraf coverage",
    "optimize": "pnpm -C examples/module-federation-example optimize && pnpm -C examples/module-federation-web-example optimize",
    "postinstall": "pnpm run build:wasm"
  },
  "dependencies": {
    "@types/node": "^20.0.0"
  },
  "devDependencies": {
    "@swc/core": "^1.3.0",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "rimraf": "^5.0.0",
    "vite-plugin-top-level-await": "^1.5.0",
    "vite-plugin-wasm": "^3.4.1",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "packageManager": "pnpm@8.11.0+sha512.9df87c16c98db27b4e051d787e67f2207ec47e809ccb07bf7b5ec4acdcd1613355839a38d0b900144923d6a7057700b74d2a0ccb1558beb241647a1206a9a7ab",
  "pnpm": {
    "overrides": {
      "@rspack/cli": "npm:@rspack-canary/cli@1.4.12-canary-ed187241-20250817101254",
      "@rspack/core": "npm:@rspack-canary/core@1.4.12-canary-ed187241-20250817101254"
    }
  }
}
